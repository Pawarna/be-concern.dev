// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Portofolio {
  id          String   @id @default(cuid())
  title       String
  description String
  imageUrl    String
  link        String
  tags        Tag[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Tag {
  id          String       @id @default(cuid())
  name        String       @unique
  portofolios Portofolio[]
}

model Admin {
  id       String    @id @default(cuid())
  username String    @unique
  password String
  artikels Artikel[]
}

enum StatusArtikel {
  DRAFT
  PUBLISHED
}

model Artikel {
  id         String        @id @default(cuid())
  title      String
  slug       String        @unique
  content    Json
  thumbnail  String
  status     StatusArtikel
  author     Admin         @relation(fields: [authorId], references: [id])
  authorId   String
  category   Category?     @relation(fields: [categoryId], references: [id])
  categoryId String?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
}

model Category {
  id       String    @id @default(cuid())
  name     String    @unique
  slug     String    @unique
  artikels Artikel[]
}
